# Database configuration
DB_HOST=localhost
DB_PORT=5430
DB_USER=player_tracker
DB_PASSWORD=player_tracker
DB_NAME=player_tracker

# Scheduler configuration
# Use a preset: every-minute, every-5-minutes, every-15-minutes, every-30-minutes,
#               every-hour, every-6-hours, every-12-hours, daily, daily-morning, daily-evening
# Or use a custom cron expression: "0 */2 * * *" (every 2 hours)
TRACK_SCHEDULE=daily

# Placement filter for tracking (e.g., "1", "1-3", "1-5")
TRACK_PLACEMENT=1-3

# Run sync immediately when scheduler starts (true/false)
TRACK_RUN_ON_START=true

# Email configuration (Gmail SMTP)
# To use Gmail, you need an App Password:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a new App Password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email recipient for notifications (defaults to SMTP_USER if not set)
EMAIL_TO=
