{
  "name": "player-tracker",
  "version": "1.0.0",
  "description": "A tool for tracking selected players' PDGA results and notifying if a tracked player performs well",
  "type": "module",
  "scripts": {
    "fetch-player": "tsx src/fetch-player-profile.ts",
    "parse-player": "tsx src/parse-player-profile.ts",
    "track": "tsx src/track-players.ts",
    "scheduler": "tsx src/scheduler.ts",
    "notify": "tsx src/notify.ts",
    "test-email": "tsx src/test-email.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:migrate": "knex migrate:latest",
    "db:migrate:rollback": "knex migrate:rollback",
    "db:migrate:make": "knex migrate:make",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest"
  },
  "keywords": [
    "pdga",
    "disc-golf",
    "player-tracking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "pg": "^8.13.0",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  }
}
